# ──────────────────────────────────────────────────────────────────────────
# Dev env örneği — apps/server (Stellar). Gerçek config şeması:
#   apps/server/src/config/index.ts
# Kopyala:  cp apps/server/.env.example apps/server/.env
# ──────────────────────────────────────────────────────────────────────────

PORT=8080
LOG_LEVEL=info
NODE_ENV=development

# Comma-separated API keys (production'da en az biri gerekir; frontend "dev-key-change-me" gönderir)
DELTAG_API_KEYS=dev-key-change-me

# Hangi ağ: testnet (ücretsiz, friendbot var) | pubnet (gerçek para)
STELLAR_NETWORK=testnet

# ZORUNLU — yoksa sunucu açılışta çöker (zod .url() ister)
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
# pubnet için:
#   STELLAR_HORIZON_URL=https://horizon.stellar.org
#   STELLAR_SOROBAN_RPC_URL=https://mainnet.sorobanrpc.com

# Opsiyonel: USDC tanımı (boşsa ağ için varsayılan Circle issuer/SAC kullanılır)
STELLAR_USDC_CODE=USDC
# STELLAR_USDC_ISSUER=G...

# Opsiyonel: risky/known-safe Soroban kontrat id'leri (C…), virgülle ayrılmış
RISKY_CONTRACT_IDS=
KNOWN_SAFE_CONTRACT_IDS=

# İstek limitleri (varsayılanlar makul)
MAX_SIMULATION_OPERATIONS=20
MAX_BODY_BYTES=1048576
REQUEST_TIMEOUT_MS=25000

# Reverse proxy / Docker arkası: gerçek istemci IP (rate limit + log)
DELTAG_TRUST_PROXY=

# --- x402 (HTTP 402 ödeme, opsiyonel; Stellar exact scheme) ---
# true yaparsan POST /v1/analyze x402 ile ücretlendirilir.
X402_ENABLED=false
# Alıcı Stellar adresi (G…). X402_ENABLED=true iken zorunlu.
X402_PAY_TO=
# CAIP-2 ağ id'si (boşsa `stellar:<STELLAR_NETWORK>` kullanılır)
X402_NETWORK=stellar:testnet
# Facilitator (boşsa https://www.x402.org/facilitator)
X402_FACILITATOR_URL=
X402_ANALYZE_PRICE=$0.001
# api_key | x402 | both — /v1/analyze'ı kim çağırabilir
DELTAG_AUTH_MODE=

# --- x402 demo paywall (apps/server/src/api/routes/demo-paywall.ts) ---
# Showcase'in Scrybe demosu (Stellar testnet x402 settlement).
X402_DEMO_NETWORK=stellar:testnet
# Soru başına fiyat, atomik USDC (7 ondalık → 1000 = $0.0001)
X402_DEMO_PRICE_ATOMIC=1000
