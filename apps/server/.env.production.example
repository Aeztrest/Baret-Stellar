# ──────────────────────────────────────────────────────────────────────────
# Production env örneği — apps/server (Stellar). Gerçek config şeması:
# apps/server/src/config/index.ts
# ──────────────────────────────────────────────────────────────────────────

NODE_ENV=production
# PORT'u Render/Koyeb gibi platformlar otomatik verir; manuel host'ta 8080 kullan.
PORT=8080
LOG_LEVEL=info

# Hangi ağ: testnet (ücretsiz, friendbot var) | pubnet (gerçek para)
STELLAR_NETWORK=testnet

# ZORUNLU — yoksa sunucu açılışta çöker (zod .url() ister)
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
# pubnet için:
#   STELLAR_HORIZON_URL=https://horizon.stellar.org
#   STELLAR_SOROBAN_RPC_URL=https://mainnet.sorobanrpc.com

# Frontend (apps/showcase) sabit "dev-key-change-me" gönderir; eşleşmesi için aynısını ver.
# Boş bırakırsan production'da uyarı verir ama tüm istekleri kabul eder (açık demo).
DELTAG_API_KEYS=dev-key-change-me

# Reverse proxy / platform arkası: gerçek istemci IP (rate limit + log)
DELTAG_TRUST_PROXY=true

# İstersen ayarla (varsayılanlar makul):
# DELTAG_RATE_LIMIT_MAX=200
# DELTAG_RATE_LIMIT_WINDOW_MS=60000
# MAX_SIMULATION_OPERATIONS=20

# x402 ödeme akışı — ücretsiz demoda kapalı tut
X402_ENABLED=false
